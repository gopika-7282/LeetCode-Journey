"""Given two strings s and t, return true if t is an anagram of s, and false otherwise.
Example 1:
Input: s = "anagram", t = "nagaram"
Output: true
Example 2:
Input: s = "rat", t = "car"
Output: false

 # Counter stores the frequency of each character in a string.
 # Two strings are anagrams if they have the same character counts.
 # Compare the frequency dictionaries and return True if they match.
Time Complexity: O(n)
Space Complexity: O(1) (or O(k), where k is the number of distinct characters)"""


from collections import Counter

class Solution:
    def isAnagram(self, s: str, t: str) -> bool:
        return Counter(s) == Counter(t)