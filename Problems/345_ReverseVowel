class Solution:
    def reverseVowels(self, s: str) -> str:
        i,j=0,len(s)-1
        vow=["a","e","i","o","u"]
        l=list(s)
        while(i<=j):
            if (s[i].lower() not in vow):
                i+=1
            elif  (s[j].lower() not in vow):
                j-=1
            else:
                temp=l[i]
                l[i]=l[j]
                l[j]=temp
                i+=1
                j-=1
            
                
            
        return "".join(l)       